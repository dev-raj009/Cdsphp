# ============================================
# SpidyUniverse — FINAL FIXED CONFIG
# ============================================

Options -Indexes
Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On

  # ✅ IMPORTANT: Allow all existing files directly
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # ✅ Allow all existing folders
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # ❌ Block direct access to /php/
  RewriteRule ^php/ - [F,L]

  # ✅ Only non-existing routes go to index.php
  RewriteRule ^ index.php [L]
</IfModule>

# Block sensitive files
<FilesMatch "^(config|api|security)\.php$">
  Require all denied
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "no-referrer"
  Header always unset X-Powered-By
</IfModule>
